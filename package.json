{
  "private": true,
  "engines": {
    "node": ">=24.3.0"
  },
  "scripts": {
    "build": "pnpm --filter @backlog-mcp/shared build && pnpm --filter @backlog-mcp/viewer typecheck && vite build && pnpm --filter backlog-mcp build",
    "build:viewer": "pnpm --filter @backlog-mcp/shared build && pnpm --filter @backlog-mcp/viewer typecheck && vite build",
    "typecheck": "pnpm --filter backlog-mcp typecheck && pnpm --filter @backlog-mcp/viewer typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter backlog-mcp test:watch",
    "search:eval": "node --experimental-strip-types scripts/search-eval.mjs",
    "suite:structural": "node --experimental-strip-types scripts/structural-suite.mjs",
    "usage:report": "node --experimental-strip-types scripts/usage-report.mjs",
    "qrels:implicit": "node scripts/implicit-qrels.mjs",
    "dev": "vite",
    "clean": "pnpm -r clean",
    "start": "pnpm --filter backlog-mcp start",
    "deploy": "pnpm --filter backlog-mcp run deploy",
    "deploy:preview": "pnpm --filter backlog-mcp run deploy:preview",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector packages/server/dist/cli/index.mjs"
  },
  "devDependencies": {
    "@nisli/core": "^0.54.0",
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.0",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
